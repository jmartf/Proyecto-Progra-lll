@model IEnumerable<Proyecto_Programacion_III.Models.Entidades.Cita>

<h2>Lista de Citas</h2>

<a asp-action="Create" class="btn btn-primary">Nueva Cita</a>

<table class="table">
    <thead>
        <tr>
            <th>Cliente</th>
            <th>Servicio</th>
            <th>Usuario</th>
            <th>Fecha</th>
            <th>Estado</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Cliente?.NombreCompleto</td>
                <td>@item.Servicio?.Nombre</td>
                <td>@item.Usuario?.Nombre</td>
                <td>@item.FechaHora</td>
                <td>@item.Estado</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>