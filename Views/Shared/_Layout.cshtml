<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Proyecto_Programacion_III</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Proyecto_Programacion_III.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body>
    @{
        var rol = Context.Session.GetString("Rol");
    }

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                Sistema de Citas
            </a>

            <div class="collapse navbar-collapse">

                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            Inicio
                        </a>
                    </li>

                    @* SOLO ADMIN *@
                    @if (rol == "Administrador")
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Usuarios" asp-action="Index">
                                Usuarios
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cliente" asp-action="Index">
                                Clientes
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Servicio" asp-action="Index">
                                Servicios
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Citas" asp-action="Index">
                                Citas
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="DashboardAdmin">
                                Dashboard Admin
                            </a>
                        </li>
                    }

                    @* USUARIO *@
                    @if (rol == "Usuario")
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Citas" asp-action="Index">
                                Citas
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cliente" asp-action="Index">
                                Clientes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="DashboardUsuario">
                                Dashboard Usuario
                            </a>
                        </li>
                    }

                </ul>

                <span class="navbar-text text-white me-3">
                    Rol: @rol
                </span>


            </div>
        </div>
    </nav>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Proyecto_Programacion_III - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
