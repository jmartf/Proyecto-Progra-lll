@model IEnumerable<Proyecto_Programacion_III.Models.Entidades.Servicio>

@{
    ViewData["Title"] = "Lista de Servicios";
}

<h2>Lista de Servicios</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Crear Servicio</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Duración</th>
            <th>Costo</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.DuracionMinutos</td>
                <td>@item.Costo</td>
                <td>@item.Estado</td>
                <td>
                  <a asp-action="Edit" asp-route-id="@item.ServicioId" class="btn btn-warning btn-sm">Editar</a>
                  <a asp-action="Delete" asp-route-id="@item.ServicioId" class="btn btn-danger btn-sm">Eliminar</a>
                </td>

            </tr>
        }
    </tbody>
</table>
