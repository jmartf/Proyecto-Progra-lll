@model Proyecto_Programacion_III.Models.Entidades.Servicio

@{
    ViewData["Title"] = "Editar Servicio";
}

<h2>Editar Servicio</h2>

<form asp-action="Edit" method="post">
    
    <input type="hidden" asp-for="ServicioId" />

    <div class="form-group">
        <label>Nombre</label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Descripción</label>
        <input asp-for="Descripcion" class="form-control" />
    </div>

    <div class="form-group">
        <label>Duración (minutos)</label>
        <input asp-for="DuracionMinutos" class="form-control" />
        <span asp-validation-for="DuracionMinutos" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Costo</label>
        <input asp-for="Costo" class="form-control" />
        <span asp-validation-for="Costo" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Estado</label>
        <select asp-for="Estado" class="form-control"
                asp-items="Html.GetEnumSelectList<Proyecto_Programacion_III.Models.Entidades.Opciones.EstadoServicio>()">
        </select>
    </div>

    <br />

    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</form>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
