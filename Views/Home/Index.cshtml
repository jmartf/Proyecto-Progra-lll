@{
    ViewData["Title"] = "Home Page";
    var rol = Context.Session.GetString("Rol");
}

<br />
<div class="text-center">
    <h1 class="display-4">Bienvenido al sistema de citas</h1>
</div>

<br />
<br />

@if (rol == "Administrador")
{
  <div class="border border-primary rounded-3 shadow p-4">
    <div class="text-center mb-4">
    <h4>Panel Administrador</h4>
    </div>

    <div class="d-flex justify-content-center gap-3">
    <a asp-controller="Usuarios" asp-action="Index" class="btn btn-dark btn-lg px-4 py-3">
        Usuarios
    <i class="bi bi-people-fill"></i>
    </a>

    <a asp-controller="Cliente" asp-action="Index" class="btn btn-dark btn-lg px-4 py-3">
        Clientes
    <i class="bi bi-person-badge-fill"></i>
    </a>

    <a asp-controller="Servicio" asp-action="Index" class="btn btn-dark btn-lg px-4 py-3">
        Servicios
    <i class="bi bi-tools"></i>
    </a>

    <a asp-controller="Citas" asp-action="Index" class="btn btn-dark btn-lg px-4 py-3">
        Citas
    <i class="bi bi-calendar-check-fill"></i>
    </a>

    <a asp-controller="Home" asp-action="DashboardAdmin" class="btn btn-dark btn-lg px-4 py-3">
        Estadísticas
    <i class="bi bi-bar-chart-fill"></i>
    </a>
    </div>
  </div>
}

@if (rol == "Usuario")
{
   <div class="border border-primary rounded-3 shadow p-4">
    <div class="text-center mb-4">
    <h4>Panel Usuario</h4>
    </div>

    <div class="d-flex justify-content-center gap-3">
    <a asp-controller="Servicio" asp-action="Index" class=" btn btn-dark btn-lg px-4 py-3"">
        Servicios
    <i class="bi bi-tools"></i>
    </a>

    <a asp-controller="Cliente" asp-action="Index" class="btn btn-dark btn-lg px-4 py-3" ">
        Clientes
    <i class="bi bi-person-badge-fill"></i>
    </a>

    <a asp-controller="Citas" asp-action="Index" class="btn btn-dark btn-lg px-4 py-3">
        Citas
    <i class="bi bi-calendar-check-fill"></i>
    </a>
    <a asp-controller="Home" asp-action="DashboardUsuario" class="btn btn-dark btn-lg px-4 py-3" ">
        Estadisticas
    <i class="bi bi-bar-chart-fill"></i>
    </a>
    </div>
   </div>
}

<br />
<br />
<br />
<br />


<div class="text-center mb-4">
    <p><strong>Rol actual:</strong> @rol</p>
</div>
<div class="d-flex justify-content-center gap-3">
    <a asp-action="LoginAdmin" class="btn btn-primary">
        Administrador
    </a>

    <a asp-action="LoginUsuario" class="btn btn-primary">
        Usuario
    </a>
</div>

<br />
<br />
<br />
<br />
<br />
<br />
